         return response()->json(['data' => true]);
     }
+
+    private function resolveBatchId(Request $request): ?string
+    {
+        $bodyBatchId = $request->input('batch_id');
+        $headerBatchId = $request->header('Idempotency-Key');
+
+        if ($bodyBatchId !== null && !is_string($bodyBatchId)) {
+            abort(422, 'batch_id must be a string');
+        }
+
+        if ($headerBatchId !== null && !is_string($headerBatchId)) {
+            abort(422, 'Idempotency-Key must be a string');
+        }
+
+        if ($bodyBatchId !== null && $headerBatchId !== null && $bodyBatchId !== $headerBatchId) {
+            abort(422, 'batch_id and Idempotency-Key must match');
+        }
+
+        $batchId = $bodyBatchId ?? $headerBatchId;
+        if ($batchId === null) {
+            return null;
+        }
+
+        if (!preg_match('/\A[A-Za-z0-9._:-]{1,128}\z/D', $batchId)) {
+            abort(422, 'Invalid batch_id');
+        }
+
+        return $batchId;
+    }
 }
