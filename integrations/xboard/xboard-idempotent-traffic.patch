diff --git a/app/Services/TrafficBatchLedger.php b/app/Services/TrafficBatchLedger.php
new file mode 100644
index 0000000..169ab32
--- /dev/null
+++ b/app/Services/TrafficBatchLedger.php
@@ -0,0 +1,259 @@
+<?php
+
+namespace App\Services;
+
+use App\Models\Server;
+use Closure;
+use InvalidArgumentException;
+use Illuminate\Support\Facades\DB;
+
+/**
+ * Durable idempotency and recovery state for batched node traffic reports.
+ *
+ * The request row stores the normalized payload until every billing component
+ * has committed. Step markers share the same transaction as each mutation, so
+ * retries and scheduled recovery can safely re-dispatch incomplete work.
+ */
+class TrafficBatchLedger
+{
+    private const REQUEST_TABLE = 'v2_server_traffic_batches';
+    private const STEP_TABLE = 'v2_server_traffic_batch_steps';
+    private const CHUNK_SIZE = 1000;
+    private const COMPONENTS_PER_CHUNK = 3;
+
+    public const ACCEPTED = 'accepted';
+    public const ALREADY_PROCESSED = 'already_processed';
+    public const CONFLICT = 'conflict';
+
+    /**
+     * Validate and canonicalize traffic for hashing, storage and billing.
+     * Batched traffic is intentionally stricter than the legacy endpoint:
+     * user IDs must be positive decimal integers and counters non-negative ints.
+     */
+    public static function normalizeTraffic(array $traffic): array
+    {
+        $data = [];
+
+        foreach ($traffic as $uid => $item) {
+            $uidString = (string) $uid;
+            if (!ctype_digit($uidString) || (int) $uidString <= 0) {
+                throw new InvalidArgumentException('Traffic user ID must be a positive integer');
+            }
+            $canonicalUID = (string) (int) $uidString;
+            if ($uidString !== $canonicalUID || array_key_exists($canonicalUID, $data)) {
+                throw new InvalidArgumentException('Traffic user ID must use unique canonical decimal form');
+            }
+            if (!is_array($item) || !array_is_list($item) || count($item) !== 2) {
+                throw new InvalidArgumentException('Traffic value must be a two-element array');
+            }
+            if (!is_int($item[0]) || !is_int($item[1]) || $item[0] < 0 || $item[1] < 0) {
+                throw new InvalidArgumentException('Traffic counters must be non-negative integers');
+            }
+
+            $data[$canonicalUID] = [$item[0], $item[1]];
+        }
+
+        ksort($data, SORT_STRING);
+
+        return $data;
+    }
+
+    public static function trafficHash(array $traffic): string
+    {
+        $normalized = self::normalizeTraffic($traffic);
+
+        return hash('sha256', self::encodePayload($normalized));
+    }
+
+    /**
+     * Atomically claim a request key and durably store enough information to
+     * reconstruct all jobs if a queue worker permanently fails.
+     */
+    public static function claimRequest(
+        int $serverId,
+        string $batchId,
+        array $traffic,
+        float $billingRate = 1.0,
+        string $protocol = ''
+    ): string
+    {
+        $normalized = self::normalizeTraffic($traffic);
+        $payload = self::encodePayload($normalized);
+        $payloadHash = hash('sha256', $payload);
+        $now = time();
+        $expectedSteps = (int) ceil(count($normalized) / self::CHUNK_SIZE) * self::COMPONENTS_PER_CHUNK;
+
+        $inserted = DB::table(self::REQUEST_TABLE)->insertOrIgnore([
+            'server_id' => $serverId,
+            'batch_id' => $batchId,
+            'payload_hash' => $payloadHash,
+            'payload' => $payload,
+            'billing_rate' => $billingRate,
+            'protocol' => $protocol,
+            'record_at' => strtotime(date('Y-m-d')),
+            'expected_steps' => $expectedSteps,
+            'completed_at' => null,
+            'created_at' => $now,
+            'updated_at' => $now,
+        ]);
+
+        if ($inserted === 1) {
+            return self::ACCEPTED;
+        }
+
+        $existing = DB::table(self::REQUEST_TABLE)
+            ->where('server_id', $serverId)
+            ->where('batch_id', $batchId)
+            ->first(['payload_hash']);
+
+        if (!$existing || !hash_equals((string) $existing->payload_hash, $payloadHash)) {
+            return self::CONFLICT;
+        }
+
+        DB::table(self::REQUEST_TABLE)
+            ->where('server_id', $serverId)
+            ->where('batch_id', $batchId)
+            ->update(['updated_at' => $now]);
+
+        return self::ALREADY_PROCESSED;
+    }
+
+    /** Return the immutable payload and billing context stored on first claim. */
+    public static function dispatchContext(int $serverId, string $batchId): array
+    {
+        $row = DB::table(self::REQUEST_TABLE)
+            ->where('server_id', $serverId)
+            ->where('batch_id', $batchId)
+            ->first();
+        if (!$row) {
+            throw new InvalidArgumentException('Traffic batch does not exist');
+        }
+
+        $traffic = json_decode((string) $row->payload, true);
+        if (!is_array($traffic) || empty($traffic)) {
+            throw new InvalidArgumentException('Traffic batch payload is invalid');
+        }
+
+        return [
+            'traffic' => self::normalizeTraffic($traffic),
+            'billing_rate' => (float) $row->billing_rate,
+            'protocol' => (string) $row->protocol,
+            'record_at' => (int) $row->record_at,
+            'completed' => $row->completed_at !== null,
+        ];
+    }
+
+    /**
+     * Run one billing component once. The marker, billing mutation and request
+     * completion transition all share the same database transaction.
+     */
+    public static function runStep(int $serverId, string $batchId, int $chunkIndex, string $component, Closure $callback): bool
+    {
+        return DB::transaction(function () use ($serverId, $batchId, $chunkIndex, $component, $callback) {
+            $now = time();
+            $inserted = DB::table(self::STEP_TABLE)->insertOrIgnore([
+                'server_id' => $serverId,
+                'batch_id' => $batchId,
+                'chunk_index' => $chunkIndex,
+                'component' => $component,
+                'created_at' => $now,
+                'updated_at' => $now,
+            ]);
+
+            if ($inserted !== 1) {
+                return false;
+            }
+
+            $callback();
+
+            $request = DB::table(self::REQUEST_TABLE)
+                ->where('server_id', $serverId)
+                ->where('batch_id', $batchId)
+                ->first(['expected_steps']);
+            if ($request) {
+                $completedSteps = DB::table(self::STEP_TABLE)
+                    ->where('server_id', $serverId)
+                    ->where('batch_id', $batchId)
+                    ->count();
+                if ($completedSteps >= (int) $request->expected_steps) {
+                    DB::table(self::REQUEST_TABLE)
+                        ->where('server_id', $serverId)
+                        ->where('batch_id', $batchId)
+                        ->update(['completed_at' => $now, 'updated_at' => $now]);
+                }
+            }
+
+            return true;
+        }, 3);
+    }
+
+    /**
+     * Re-dispatch incomplete durable batches. Step ledgers make duplicate jobs
+     * harmless; this is an outbox recovery pass, not a second billing path.
+     */
+    public static function recoverIncomplete(int $olderThanSeconds = 120, int $limit = 100): int
+    {
+        $cutoff = time() - max(0, $olderThanSeconds);
+        $rows = DB::table(self::REQUEST_TABLE)
+            ->whereNull('completed_at')
+            ->where('updated_at', '<=', $cutoff)
+            ->orderBy('id')
+            ->limit(max(1, $limit))
+            ->get();
+        $dispatched = 0;
+
+        foreach ($rows as $row) {
+            $server = Server::find($row->server_id);
+            $traffic = json_decode((string) $row->payload, true);
+            if (!$server || !is_array($traffic) || empty($traffic)) {
+                continue;
+            }
+
+            ServerService::processTraffic(
+                $server,
+                self::normalizeTraffic($traffic),
+                (string) $row->batch_id,
+                (float) $row->billing_rate,
+                (string) $row->protocol,
+                (int) $row->record_at
+            );
+            DB::table(self::REQUEST_TABLE)
+                ->where('id', $row->id)
+                ->update(['updated_at' => time()]);
+            $dispatched++;
+        }
+
+        return $dispatched;
+    }
+
+    /** Remove only completed ledgers outside the retry/reconciliation window. */
+    public static function pruneCompleted(int $olderThanTimestamp, int $limit = 1000): int
+    {
+        $rows = DB::table(self::REQUEST_TABLE)
+            ->whereNotNull('completed_at')
+            ->where('completed_at', '<', $olderThanTimestamp)
+            ->orderBy('id')
+            ->limit(max(1, $limit))
+            ->get(['id', 'server_id', 'batch_id']);
+
+        foreach ($rows as $row) {
+            DB::transaction(function () use ($row) {
+                DB::table(self::STEP_TABLE)
+                    ->where('server_id', $row->server_id)
+                    ->where('batch_id', $row->batch_id)
+                    ->delete();
+                DB::table(self::REQUEST_TABLE)->where('id', $row->id)->delete();
+            });
+        }
+
+        return $rows->count();
+    }
+
+    private static function encodePayload(array $traffic): string
+    {
+        return json_encode(
+            $traffic,
+            JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PRESERVE_ZERO_FRACTION | JSON_THROW_ON_ERROR
+        );
+    }
+}
